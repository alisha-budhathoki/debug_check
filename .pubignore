# Build output is checked into this repo, so pub would otherwise ship it —
# a 45 MB test-cache .dill made the published archive 15 MB compressed.
build/
example/build/

# The README's hero GIF is 2.7 MB and loads from raw.githubusercontent, so the
# archive never needs it. The static PNGs below it DO ship — pubspec's
# `screenshots:` entries must resolve inside the package.
screenshots/00-demo.gif

# Not useful to consumers of the package.
example/android/
example/macos/
example/integration_test/
example/test_driver/
.dart_tool/
